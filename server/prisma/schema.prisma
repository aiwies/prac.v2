generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  OWNER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model User {
  id           String   @id @default(cuid())
  name         String   @default("Гость")
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  bookings     Booking[]
  reviews      Review[]
}

model Listing {
  id          String   @id @default(cuid())
  title       String
  city        String
  description String
  price       Int
  rating      Float    @default(0)
  categoryId  String   @default("hotel")
  amenities   String[] @default([])
  image       String?
  isHidden    Boolean  @default(false)
  ownerId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  bookings    Booking[]
  reviews     Review[]

  @@unique([title, city], name: "title_city")
}

model Booking {
  id         String        @id @default(cuid())
  checkIn    DateTime
  checkOut   DateTime
  guests     Int
  totalPrice Int           @default(0)
  status     BookingStatus @default(CONFIRMED)
  createdAt  DateTime      @default(now())
  userId     String
  listingId  String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing    Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  text      String
  createdAt DateTime @default(now())
  userId    String
  listingId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}
